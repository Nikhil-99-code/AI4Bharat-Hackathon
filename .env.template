# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# DynamoDB Configuration
TABLE_NAME=agri-nexus-data

# S3 Configuration
IMAGE_BUCKET=agri-nexus-images

# API Gateway Configuration
API_GATEWAY_URL=https://your-api-gateway-url.amazonaws.com/prod

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_TEMPERATURE=0.3
BEDROCK_MAX_TOKENS=2048

# Application Configuration
ENVIRONMENT=development
MAX_IMAGE_SIZE_MB=10
MAX_AUDIO_DURATION_SEC=60
SESSION_TIMEOUT_MINUTES=30

# SNS Configuration (for SMS notifications)
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:agri-nexus-alerts

# Supported Languages
SUPPORTED_LANGUAGES=en,bn,hi
DEFAULT_LANGUAGE=en
